{
  "manifest_version": 3,
  "name": "Code Sync to GitHub",
  "version": "1.0.0",
  "description": "Auto push LeetCode/HackerRank submissions to GitHub",

  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://www.hackerrank.com/*",
    "https://api.github.com/*"
  ],

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content/leetcode.js"]
    },
    {
      "matches": ["https://www.hackerrank.com/*"],
      "js": ["content/hackerrank.js"]
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["content/inject.js"],
      "matches": ["https://leetcode.com/*"]
    }
  ]
}